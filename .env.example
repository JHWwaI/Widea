# ──────────────────────────────────────────
# Widea 백엔드 환경변수 — 운영 배포 템플릿
# 실제 값은 .env 또는 호스팅 대시보드(Railway/Fly)에 설정
# ──────────────────────────────────────────

# Server
PORT=3001
APP_BASE_URL=https://widea.kr

# Database (Railway/Supabase/Neon 발급 URL)
DATABASE_URL=postgresql://user:pass@host:5432/widea

# Auth
JWT_SECRET=replace-with-32+char-random-string

# Admin 권한 부여 이메일 (콤마 구분)
ADMIN_EMAILS=admin@widea.kr

# ── LLM ──
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_CHAIN=gemini-2.0-flash,gemini-flash-latest

# Groq (Whisper + Llama 폴백)
GROQ_API_KEY=
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_IDEA_MODEL=llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# ── Vector DB ──
PINECONE_API_KEY=
PINECONE_INDEX_NAME=widea-benchmarks

# ── Search (선택) ──
TAVILY_API_KEY=

# ── 결제 ──
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ── Email (회원가입 인증) ──
GMAIL_USER=
GMAIL_APP_PASSWORD=
SUPPORT_EMAIL=support@widea.kr

# ── 화상 회의 ──
JITSI_SERVER=https://meet.jit.si
